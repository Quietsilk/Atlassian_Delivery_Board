# AI Delivery Analyst — Environment Variables
#
# Jira credentials вводятся в UI дашборда (localhost:5678)
# и хранятся в localStorage браузера — в .env не нужны.
#
# Здесь только серверные интеграции.

# OpenAI — для AI-анализа (Summary / Risks / Actions)
# Если не задан — метрики работают, AI-панели показывают подсказку.
OPENAI_API_KEY=

# Telegram — для автоматической отправки отчёта после каждого синка
# Если не задан — отчёт только в дашборде.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
