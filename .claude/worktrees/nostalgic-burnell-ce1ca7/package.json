{
  "name": "ai-delivery-analyst",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MVP service for collecting Jira delivery metrics, analyzing them with AI, and sending actionable reports.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --loader ts-node/esm src/index.ts",
    "jira:inspect": "node --loader ts-node/esm src/scripts/inspectJira.ts",
    "jira:simulate": "node --loader ts-node/esm src/scripts/simulateJira.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --loader ts-node/esm --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
